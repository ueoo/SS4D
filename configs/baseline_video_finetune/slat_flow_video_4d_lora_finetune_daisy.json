{
    "models": {
        "denoiser": {
            "name": "LoRAElasticSLatFlow4DModel",
            "args": {
                "resolution": 64,
                "in_channels": 8,
                "out_channels": 8,
                "model_channels": 1024,
                "cond_channels": 1024,
                "num_blocks": 24,
                "num_heads": 16,
                "mlp_ratio": 4,
                "patch_size": 2,
                "num_io_res_blocks": 2,
                "num_io_res4d_blocks": 2,
                "io_block_channels": [
                    128
                ],
                "io_block_channels_t": [
                    1024
                ],
                "pe_mode": "rope_t",
                "qk_rms_norm": true,
                "use_fp16": true,
                "expand_self_attn": true,
                "use_checkpoint": true,
                "conv_type": "3D_1D",
                "lora_r": 8,
                "lora_alpha": 16.0,
                "lora_dropout": 0.0,
                "lora_train_bias": false
            }
        }
    },
    "dataset": {
        "name": "VideoConditionedSLat",
        "args": {
            "latent_model": "dinov2_vitl14_reg_slat_vae_f16_fullfinetune_flowers_daisyfull_fix_t_step0030000",
            "image_size": 518,
            "num_frames": 4,
            "frame_step": 10,
            "normalization": {
                "mean": [
                    -2.826356,
                    0.33626583,
                    0.0763019,
                    -0.117598,
                    -0.4892621,
                    1.0101169,
                    -1.0808244,
                    1.4578744
                ],
                "std": [
                    2.8175173,
                    2.6447911,
                    2.5076609,
                    2.3946748,
                    3.438241,
                    2.864445,
                    3.2401907,
                    3.1412923
                ]
            },
            "pretrained_slat_dec": "lizb6626/SS4D/ckpts/slat_dec_gs_4d"
        }
    },
    "trainer": {
        "name": "VideoConditionedSparseFlowMatchingCFGTrainer",
        "args": {
            "max_steps": 1000,
            "batch_size_per_gpu": 1,
            "batch_split": 1,
            "num_workers": 4,
            "optimizer": {
                "name": "AdamW",
                "args": {
                    "lr": 0.0001,
                    "weight_decay": 0.0
                }
            },
            "ema_rate": [
                0.9999
            ],
            "fp16_mode": "inflat_all",
            "fp16_scale_growth": 0.001,
            "elastic": {
                "name": "LinearMemoryController",
                "args": {
                    "target_ratio": 0.75,
                    "max_mem_ratio_start": 0.5
                }
            },
            "grad_clip": {
                "name": "AdaptiveGradClipper",
                "args": {
                    "max_norm": 1.0,
                    "clip_percentile": 95
                }
            },
            "i_log": 50,
            "i_sample": 250,
            "i_save": 250,
            "p_uncond": 0.1,
            "t_schedule": {
                "name": "logitNormal",
                "args": {
                    "mean": 1.0,
                    "std": 1.0
                }
            },
            "sigma_min": 1e-5,
            "image_cond_model": "dinov2_vitl14_reg",
            "trainable_param_names": [
                "lora_A",
                "lora_B"
            ],
            "finetune_ckpt": {
                "denoiser": "lizb6626/SS4D/ckpts/slat_flow_video_4d"
            }
        }
    }
}
